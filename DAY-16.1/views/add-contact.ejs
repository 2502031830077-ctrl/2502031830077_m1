<%- include('partials/header.ejs') %>

<main class="py-5">
  <div class="container">
    <div class="row justify-content-md-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header"><strong>Add New Contact</strong></div>
          <div class="card-body">
            <style>
              .custom-form-table {
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                border-radius: 8px;
                overflow: hidden;
              }
              .custom-form-table th {
                background-color: #f8f9fa;
                color: #495057;
                font-weight: 600;
                vertical-align: middle;
              }
              .custom-form-table td {
                vertical-align: middle;
              }
            </style>

            <form action="/add-contact" method="POST">
              <table class="table table-bordered custom-form-table mb-4">
                <tbody>
                  <tr>
                    <th scope="row" style="width: 30%;"><label for="first_name" class="mb-0"><i class="fa fa-user text-primary mr-2"></i> First Name</label></th>
                    <td><input type="text" name="first_name" id="first_name" class="form-control" required></td>
                  </tr>
                  <tr>
                    <th scope="row"><label for="last_name" class="mb-0"><i class="fa fa-user text-primary mr-2"></i> Last Name</label></th>
                    <td><input type="text" name="last_name" id="last_name" class="form-control" required></td>
                  </tr>
                  <tr>
                    <th scope="row"><label for="email" class="mb-0"><i class="fa fa-envelope text-info mr-2"></i> Email</label></th>
                    <td><input type="email" name="email" id="email" class="form-control" required></td>
                  </tr>
                  <tr>
                    <th scope="row"><label for="phone" class="mb-0"><i class="fa fa-phone text-success mr-2"></i> Phone</label></th>
                    <td><input type="text" name="phone" id="phone" class="form-control" required></td>
                  </tr>
                  <tr>
                    <th scope="row"><label for="address" class="mb-0"><i class="fa fa-map-marker text-danger mr-2"></i> Address</label></th>
                    <td><textarea name="address" id="address" rows="3" class="form-control" required></textarea></td>
                  </tr>
                </tbody>
              </table>
              <hr>
              <div class="form-group row mb-0 text-center">
                <div class="col-md-12">
                  <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm"><i class="fa fa-save"></i> Save</button>
                  <a href="/" class="btn btn-secondary px-4 rounded-pill shadow-sm mx-2"><i class="fa fa-times"></i> Cancel</a>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer.ejs') %>
