<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Contact App' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Top Branding Header -->
    <header class="app-header">
        <div class="header-container">
            <a href="/" class="logo-link"><span class="logo-text">CONTACT APP</span></a>
            <span class="db-status <%= dbMode === 'MongoDB' ? 'status-online' : 'status-fallback' %>">
                <span class="status-dot"></span>
                <%= dbMode === 'MongoDB' ? 'MongoDB (Online)' : 'Local File (Offline Fallback)' %>
            </span>
        </div>
    </header>

    <!-- Main Container -->
    <main class="app-container">
