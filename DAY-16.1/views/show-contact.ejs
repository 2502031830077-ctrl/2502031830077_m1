<%- include('partials/header.ejs') %>

<main class="py-5">
  <div class="container">
    <div class="row justify-content-md-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header card-title">
            <strong>Contact Details</strong>
          </div>
          <div class="card-body">
            <style>
              .custom-show-table {
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                border-radius: 8px;
                overflow: hidden;
              }
              .custom-show-table th {
                background-color: #f8f9fa;
                color: #495057;
                font-weight: 600;
                vertical-align: middle;
              }
              .custom-show-table td {
                color: #6c757d;
                vertical-align: middle;
              }
            </style>
            
            <table class="table table-bordered table-hover custom-show-table mb-4">
              <tbody>
                <tr>
                  <th scope="row" style="width: 30%;"><i class="fa fa-user text-primary mr-2"></i> Name</th>
                  <td><%= contact.first_name %> <%= contact.last_name %></td>
                </tr>
                <tr>
                  <th scope="row"><i class="fa fa-envelope text-info mr-2"></i> Email</th>
                  <td><%= contact.email %></td>
                </tr>
                <tr>
                  <th scope="row"><i class="fa fa-phone text-success mr-2"></i> Phone</th>
                  <td><%= contact.phone %></td>
                </tr>
                <tr>
                  <th scope="row"><i class="fa fa-map-marker text-danger mr-2"></i> Address</th>
                  <td><%= contact.address %></td>
                </tr>
              </tbody>
            </table>

            <hr>
            <div class="form-group row mb-0 text-center">
              <div class="col-md-12">
                <a href="/update-contact/<%= contact._id %>" class="btn btn-info px-4 rounded-pill shadow-sm"><i class="fa fa-edit"></i> Edit</a>
                <a href="/delete-contact/<%= contact._id %>" class="btn btn-danger px-4 rounded-pill shadow-sm mx-2" onclick="return confirm('Are you sure you want to delete this contact?')"><i class="fa fa-times"></i> Delete</a>
                <a href="/" class="btn btn-secondary px-4 rounded-pill shadow-sm"><i class="fa fa-arrow-left"></i> Back</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer.ejs') %>
